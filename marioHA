### Prerequisites:

# Install and start the cluster software

# Configure fencing for the cluster



# Enable the repo on all nodes:

subscription-manager repos --enable=rhel-8-for-x86_64-resilientstorage-rpms



# Install RPMs on all nodes:

yum install lvm2-lockd gfs2-utils dlm



# On both nodes set in the /etc/lvm/lvm.conf:

use_lvmlockd = 1



# Set no-quorum-policy to freeze:

pcs property set no-quorum-policy=freeze



# Set up a dlm resource:

# Will be part of a resource group named locking!

pcs resource create dlm --group locking ocf:pacemaker:controld op monitor interval=30s on-fail=fence



# Clone the locking resource group, so it can be active on both nodes:

pcs resource clone locking interleave=true



# Set up an lvmlockd resource as part of the group locking:

pcs resource create lvmlockd --group locking ocf:heartbeat:lvmlockd op monitor interval=30s on-fail=fence



# Check the status of the cluster to ensure that the locking resource group has started on both nodes of the cluster:

pcs status --full

